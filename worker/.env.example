# Supabase（worker 用 service role key，bypass RLS）
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=xxxxxxxx

# 搜尋引擎 API（MVP 使用 SerpAPI 的 Google 搜尋結果）
SERPAPI_KEY=xxxxxxxx

# 排除自家網域（例如你自己就是 petline.com.hk，查自己的 SKU 不需要撈回自己網站）
# 逗號分隔多個網域，留空則不排除任何網域
SEARCH_EXCLUDE_DOMAINS=petline.com.hk,www.petline.com.hk

# 翻譯成繁體中文 (zh-HK) 用的 LLM API（OpenAI 相容介面，留空則不翻譯、原文照搬）
TRANSLATE_API_KEY=
TRANSLATE_API_BASE=https://api.openai.com/v1
TRANSLATE_MODEL=gpt-4o-mini
